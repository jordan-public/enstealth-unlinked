# Private keys (DO NOT COMMIT REAL VALUES)
# For local Anvil testing only (default test account)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# For Sepolia testnet deployment (use YOUR key, not the Anvil default!)
# Option 1: Use private key directly
SEPOLIA_PRIVATE_KEY=your_sepolia_private_key_here
# Option 2: Use mnemonic (script will derive account 0)
SEPOLIA_MNEMONIC="your twelve word mnemonic phrase here"

# RPC URLs
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Contract addresses (filled after deployment)
NEXT_PUBLIC_STEALTH_PAYMENT_ADDRESS=
NEXT_PUBLIC_ENS_REGISTRAR_ADDRESS=

# API Keys
ETHERSCAN_API_KEY=your_etherscan_api_key

# Safety toggles for local testing (prevents broadcasting real transactions)
PRIVATE_PAYMENT_DRY_RUN=false
NO_BROADCAST=false

# WalletConnect/Reown
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id
NEXT_PUBLIC_PRIVATE_PAYMENT_DRY_RUN=false

# Unlink SDK private rail (token-based)
# Set to true to enable SDK path on /api/private-payment.
# If false or missing, backend falls back to relayer-funded ETH sendFunds flow.
UNLINK_USE_SDK=false
UNLINK_API_KEY=your_unlink_api_key
UNLINK_MNEMONIC="your twelve word unlink mnemonic phrase here"
UNLINK_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
UNLINK_TOKEN_DECIMALS=18

# Optional overrides for Unlink SDK engine and Base Sepolia RPC
UNLINK_API_URL=https://staging-api.unlink.xyz
UNLINK_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# EVM key used by unlinkEvm.fromViem (falls back to SEPOLIA_PRIVATE_KEY if omitted)
UNLINK_EVM_PRIVATE_KEY=your_base_sepolia_private_key_here

# Public config used by withdraw UI for token-rail scanning on Base Sepolia
NEXT_PUBLIC_UNLINK_ENABLED=false
NEXT_PUBLIC_UNLINK_API_URL=https://staging-api.unlink.xyz
NEXT_PUBLIC_UNLINK_CHAIN_ID=84532
NEXT_PUBLIC_UNLINK_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_UNLINK_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_UNLINK_TOKEN_DECIMALS=18
NEXT_PUBLIC_UNLINK_TOKEN_SYMBOL=TOKEN
