# Private keys (DO NOT COMMIT REAL VALUES)
# For local Anvil testing only (default test account)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# For Sepolia testnet deployment (use YOUR key, not the Anvil default!)
# Option 1: Use private key directly
SEPOLIA_PRIVATE_KEY=your_sepolia_private_key_here
# Option 2: Use mnemonic (script will derive account 0)
SEPOLIA_MNEMONIC="your twelve word mnemonic phrase here"

# RPC URLs
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Contract addresses (filled after deployment)
NEXT_PUBLIC_STEALTH_PAYMENT_ADDRESS=

# API Keys
ETHERSCAN_API_KEY=your_etherscan_api_key

# WalletConnect/Reown
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id

# Unlink API (if applicable)
UNLINK_API_KEY=your_unlink_api_key
